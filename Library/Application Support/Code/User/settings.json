{
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.formatOnPaste": true,
    "window.zoomLevel": -0.8,
    "editor.fontSize": 15,
    "chat.fontSize": 15,
    "debug.console.fontSize": 15,
    "scm.inputFontSize": 10,
    "editor.fontFamily": "",
    "editor.accessibilitySupport": "off",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.defaultLocation": "editor",
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "prettier.tabWidth": 4,
    "workbench.startupEditor": "none",
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "explorer.confirmDelete": false,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "explorer.confirmPasteNative": false,
    "editor.wordWrap": "on",
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "C_Cpp.formatting": "clangFormat",
    "security.workspace.trust.untrustedFiles": "open",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportGeneralTypeIssues": "none",
    },
    "python.analysis.autoImportCompletions": true,
    "python.analysis.stubPath": "",
    "window.autoDetectColorScheme": true,
    "chat.editing.confirmEditRequestRemoval": false,
    "explorer.autoReveal": false,
    "editor.hover.enabled": "on",
    "workbench.hover.delay": 500,
    "terminal.integrated.fontSize": 15,
    "notebook.output.scrolling": true,
    "editor.scrollbar.vertical": "hidden",
    "chat.viewSessions.orientation": "stacked",
    "markdown.preview.fontSize": 15,
    "chat.editor.fontSize": 15,
    "workbench.browser.openLocalhostLinks": false,
    "workbench.colorCustomizations": {},
    "workbench.editorAssociations": {
        "*.md": "vscode.markdown.preview.editor",
        "*.markdown": "vscode.markdown.preview.editor",
    },
    "workbench.diffEditorAssociations": {
        "*.md": "vscode.markdown.preview.editor",
        "*.markdown": "vscode.markdown.preview.editor",
    },
    "diffEditor.renderSideBySide": false,
    "editor.minimap.enabled": false,
    "scm.diffDecorations": "gutter",
    "chat.disableAIFeatures": true,
    "workbench.editor.enablePreview": true,
    "workbench.editor.enablePreviewFromQuickOpen": true,
    "workbench.editor.showTabs": "single",
    "workbench.editor.limit.enabled": true,
    "workbench.editor.limit.value": 1,
    "workbench.editor.limit.perEditorGroup": true,
    "workbench.editor.labelFormat": "long",
    "workbench.preferredDarkColorTheme": "Pitch Black",
    "notebook.output.textLineLimit": 500,
    "notebook.output.wordWrap": true,
    "vim.useSystemClipboard": true,

    "vim.normalModeKeyBindingsNonRecursive": [
        {
            "before": ["H"],
            "after": ["^"],
        },
        {
            "before": ["L"],
            "after": ["$"],
        },
        {
            "before": ["U"],
            "after": ["<C-r>"],
        },
        {
            "before": ["<space>", "<space>"],
            "commands": ["workbench.action.files.save"],
        },
        {
            "before": [":", "w"],
            "commands": [
                "workbench.action.files.save",
                "editor.action.formatDocument",
            ],
        },
    ],

    "vim.visualModeKeyBindingsNonRecursive": [
        {
            "before": ["J"],
            "commands": ["editor.action.moveLinesDownAction"],
        },
        {
            "before": ["K"],
            "commands": ["editor.action.moveLinesUpAction"],
        },
    ],
    "editor.suggest.preview": true,
    "editor.parameterHints.enabled": true,
    "editor.parameterHints.cycle": true,
    "cSpell.enabled": false,
    "[plaintext]": {
        "cSpell.enabled": true,
    },
    "[markdown]": {
        "cSpell.enabled": true,
    },
    "[latex]": {
        "cSpell.enabled": true,
    },
    "[tex]": {
        "cSpell.enabled": true,
    },
    "[restructuredtext]": {
        "cSpell.enabled": true,
    },
    "[asciidoc]": {
        "cSpell.enabled": true,
    },
}
