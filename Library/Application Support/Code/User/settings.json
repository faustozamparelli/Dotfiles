{
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.pdf": "latex-workshop-pdf-hook",
    },
    "editor.minimap.enabled": false,
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.formatOnPaste": true,
    "window.zoomLevel": 1,
    "editor.fontSize": 14,
    "chat.fontSize": 10,
    "debug.console.fontSize": 10,
    "scm.inputFontSize": 10,
    "editor.fontFamily": "",
    "editor.accessibilitySupport": "off",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.defaultLocation": "editor",
    "workbench.colorTheme": "Eva Dark Bold",
    "workbench.sideBar.location": "right",
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "prettier.tabWidth": 4,
    "explorer.confirmDelete": false,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "tinymist.preview.cursorIndicator": true,
    "tinymist.lint.enabled": true,
    "explorer.confirmPasteNative": false,
    "editor.wordWrap": "on",
    "terminal.integrated.fontSize": 14,
    "chat.viewSessions.orientation": "stacked",
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": false,
        "scminput": false,
    },
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "C_Cpp.formatting": "clangFormat",
    "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, BreakBeforeBraces: Attach }",
    "code-runner.runInTerminal": true,
    "code-runner.saveAllFilesBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "code-runner.executorMap": {
        "c": "cd $dir && clang *.c -o app && ./app",
        "cpp": "cd $dir && clang++ *.cpp -o app && ./app",
    },
}
