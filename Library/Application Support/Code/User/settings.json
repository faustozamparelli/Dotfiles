{
    "workbench.editorAssociations": {
        "*.copilotmd": "vscode.markdown.preview.editor",
        "*.pdf": "latex-workshop-pdf-hook",
    },
    "editor.minimap.enabled": false,
    "files.autoSave": "afterDelay",
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.formatOnPaste": true,
    "window.zoomLevel": 0,
    "editor.fontSize": 14,
    "chat.fontSize": 10,
    "debug.console.fontSize": 10,
    "scm.inputFontSize": 10,
    "editor.fontFamily": "",
    "editor.accessibilitySupport": "off",
    "terminal.integrated.defaultProfile.osx": "fish",
    "terminal.integrated.cursorStyle": "line",
    "terminal.integrated.defaultLocation": "editor",
    "[jsonc]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
    },
    "prettier.tabWidth": 4,
    "editor.tabSize": 4,
    "editor.insertSpaces": true,
    "editor.detectIndentation": false,
    "explorer.confirmDelete": false,
    "git.enableSmartCommit": true,
    "git.confirmSync": false,
    "git.autofetch": true,
    "tinymist.preview.cursorIndicator": true,
    "tinymist.lint.enabled": true,
    "explorer.confirmPasteNative": false,
    "editor.wordWrap": "on",
    "chat.viewSessions.orientation": "stacked",
    "[c]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "[cpp]": {
        "editor.defaultFormatter": "ms-vscode.cpptools",
    },
    "C_Cpp.formatting": "clangFormat",
    "code-runner.runInTerminal": true,
    "code-runner.saveAllFilesBeforeRun": true,
    "code-runner.clearPreviousOutput": true,
    "code-runner.executorMap": {
        "c": "cd $dir && clang *.c -o app && ./app",
        "cpp": "cd $dir && clang++ *.cpp -o app && ./app",
    },
    "security.workspace.trust.untrustedFiles": "open",
    "[python]": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "charliermarsh.ruff",
    },
    "ruff.lint.ignore": ["E702"],
    "python.languageServer": "Pylance",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.diagnosticMode": "openFilesOnly",
    "python.analysis.diagnosticSeverityOverrides": {
        "reportGeneralTypeIssues": "none",
    },
    "python.analysis.autoImportCompletions": true,
    "python.analysis.stubPath": "",
    "workbench.editor.enablePreview": false,
    "workbench.editor.enablePreviewFromQuickOpen": false,
    "github.copilot.enable": {
        "*": false,
        "plaintext": false,
        "markdown": true,
        "scminput": false,
    },
    "workbench.preferredDarkColorTheme": "GitHub Dark Default",
    "workbench.preferredLightColorTheme": "GitHub Light Default",
    "workbench.colorTheme": "Eva Light",
    "window.autoDetectColorScheme": true,
    "chat.editing.confirmEditRequestRemoval": false,
    "explorer.autoReveal": false,
    "editor.hover.enabled": "on",
    "workbench.hover.delay": 500,
    "terminal.integrated.fontSize": 10,
    "C_Cpp.clang_format_fallbackStyle": "LLVM",
    "C_Cpp.clang_format_style": "{ BasedOnStyle: LLVM, IndentWidth: 4, TabWidth: 4, UseTab: Never }",
    "notebook.output.scrolling": true,
}
