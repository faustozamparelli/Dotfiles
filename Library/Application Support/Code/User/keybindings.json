// Place your key bindings in this file to override the defaults
[
    {
        "key": "cmd+0",
        "command": "workbench.action.zoomReset",
    },
    {
        "key": "cmd+numpad0",
        "command": "-workbench.action.zoomReset",
    },
    {
        "key": "cmd+h",
        "command": "workbench.action.previousEditor",
    },
    {
        "key": "cmd+l",
        "command": "workbench.action.nextEditor",
    },
    {
        "key": "cmd+shift+h",
        "command": "workbench.action.moveEditorLeftInGroup",
    },
    {
        "key": "cmd+shift+l",
        "command": "workbench.action.moveEditorRightInGroup",
    },
    {
        "key": "shift+cmd+,",
        "command": "workbench.action.openSettingsJson",
    },
    {
        "key": "cmd+r",
        "command": "code-runner.run",
    },
    {
        "key": "ctrl+alt+n",
        "command": "-code-runner.run",
    },
    {
        "key": "cmd+k cmd+m",
        "command": "workbench.action.maximizeEditorHideSidebar",
        "when": "auxiliaryBarVisible || sideBarVisible || editorPartMultipleEditorGroups && !editorPartMaximizedEditorGroup",
    },
    {
        "key": "cmd+s",
        "command": "workbench.action.toggleSidebarVisibility",
    },
    {
        "key": "cmd+b",
        "command": "-workbench.action.toggleSidebarVisibility",
    },
    {
        "key": "shift+cmd+s",
        "command": "workbench.action.toggleAuxiliaryBar",
    },
    {
        "key": "alt+cmd+b",
        "command": "-workbench.action.toggleAuxiliaryBar",
    },
    {
        "key": "ctrl+s",
        "command": "workbench.action.files.save",
    },
    {
        "key": "cmd+s",
        "command": "-workbench.action.files.save",
    },
    {
        "key": "shift+tab",
        "command": "-editor.action.inlineSuggest.commitAlternativeAction",
        "when": "inlineEditIsVisible && inlineSuggestionAlternativeActionVisible",
    },
    {
        "key": "shift+tab",
        "command": "-editor.action.inlineSuggest.commitAlternativeAction",
        "when": "inInlineEditsPreviewEditor",
    },
    {
        "key": "ctrl+c",
        "command": "problems-copy.copyAll",
        "args": {
            "errors": true,
            "simpleTemplate": true,
        },
    },
    {
        "key": "cmd+a",
        "command": "type",
        "args": {
            "text": "",
        },
    },
    {
        "key": "cmd+a",
        "command": "extension.vim_escape",
        "when": "editorTextFocus && vim.active && vim.mode == 'Insert'",
    },
    {
        "key": "cmd+a",
        "command": "extension.vim_escape",
        "when": "editorTextFocus && vim.active && vim.mode == 'Visual'",
    },
    {
        "key": "cmd+a",
        "command": "extension.vim_escape",
        "when": "editorTextFocus && vim.active && vim.mode == 'VisualLine'",
    },
    {
        "key": "cmd+a",
        "command": "extension.vim_escape",
        "when": "editorTextFocus && vim.active && vim.mode == 'VisualBlock'",
    },
    {
        "key": "cmd+t",
        "command": "workbench.action.createTerminalEditorSide",
    },
    {
        "key": "cmd+l",
        "command": "workbench.action.focusRightGroup",
    },
    {
        "key": "cmd+k cmd+right",
        "command": "-workbench.action.focusRightGroup",
    },
    {
        "key": "cmd+h",
        "command": "workbench.action.focusLeftGroup",
    },
    {
        "key": "cmd+k cmd+left",
        "command": "-workbench.action.focusLeftGroup",
    },
]
