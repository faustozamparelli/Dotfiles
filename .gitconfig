[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[user]
	name = fast
	email = fausto.zamparelli@gmail.com


[init]
	defaultBranch = main
[push]
	autoSetupRemote = true
	default = current
[alias]
	undo = reset -- soft HEAD^
[core]
	pager = delta
	editor = code --wait
[delta]
	line-numbers = true