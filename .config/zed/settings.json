{
  "outline_panel": {
    "dock": "right"
  },
  "collaboration_panel": {
    "dock": "right"
  },
  "git_panel": {
    "dock": "right",
    "tree_view": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "github-copilot-cli": {
      "type": "registry"
    }
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false
    },
    "dock": "left",
    "tool_permissions": {
      "default": "allow",
      "tools": {}
    },
    "play_sound_when_agent_done": "always",
    "default_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
      "enable_thinking": false,
      "effort": "high"
    },
    "favorite_models": [],
    "model_parameters": []
  },
  "edit_predictions": {
    "provider": "copilot"
  },
  "ui_font_weight": 300.0,
  "ui_font_family": "SF Mono",
  "buffer_line_height": "standard",
  "buffer_font_weight": 400.0,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "project_panel": {
    "dock": "right",
    "auto_reveal_entries": false
  },
  "base_keymap": "VSCode",
  "preview_tabs": {
    "enabled": false,
    "enable_preview_from_file_finder": false
  },
  "minimap": {
    "show": "never"
  },
  "auto_indent_on_paste": true,
  "use_on_type_format": true,
  "soft_wrap": "editor_width",
  "hard_tabs": false,
  "tab_size": 4,
  "agent_buffer_font_size": 18.0,
  "agent_ui_font_size": 18.0,
  "buffer_font_family": "SF Mono",
  "format_on_save": "off",
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Light Charmed Icons",
    "dark": "Light Charmed Icons"
  },
  "terminal": {
    "font_weight": 400.0,
    "cursor_shape": "bar",
    "font_size": 18.0,
    "working_directory": "current_file_directory",
    "font_family": "SF Mono",
    "shell": {
      "program": "fish"
    },
    "dock": "right"
  },
  "scrollbar": {
    "show": "never"
  },
  "vim_mode": false,
  "ui_font_size": 16.0,
  "buffer_font_size": 16.0,
  "theme": {
    "mode": "system",
    "light": "Fleet Light",
    "dark": "Fleet Dark"
  }
}
