[
  {
    "context": "Workspace",
    "bindings": {
      "cmd-;": "zed::OpenKeymap",
    },
  },
  {
    "bindings": {
      "cmd-,": "zed::OpenSettings",
    },
  },
  {
    "bindings": {
      "cmd-enter": "workspace::ToggleAllDocks",
    },
  },
  {
    "bindings": {
      "cmd-h": "vim::GoToPreviousTab",
      "cmd-l": "vim::GoToTab",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "cmd-t": "terminal_panel::Toggle"
    }
  },
  {
    "context": "Workspace",
    "unbind": {
      "ctrl-`": "terminal_panel::Toggle"
    }
  }
]
