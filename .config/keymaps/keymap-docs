#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "$0")" && pwd)"
registry="$root/registry.tsv"
reference="$HOME/.config/sync/README.md"
table="$(mktemp)"
rendered="$(mktemp)"
trap 'rm -f "$table" "$rendered"' EXIT

awk -F '\t' '
  BEGIN {
    print "| Layer | Category | Key | Behavior |"
    print "|---|---|---|---|"
  }
  /^#/ || NF == 0 { next }
  { printf "| %s | %s | `%s` | %s |\n", $2, $3, $4, $6 }
' "$registry" > "$table"

awk -F '\t' '
  /^#/ || NF == 0 { next }
  NF != 6 { printf "invalid registry row %d\n", NR > "/dev/stderr"; bad = 1 }
  seen[$2 SUBSEP $4]++ { printf "duplicate binding: %s %s\n", $2, $4 > "/dev/stderr"; bad = 1 }
  $3 == "Command" && $4 !~ /^Cmd-/ { printf "Command-category key must use Cmd: %s\n", $4 > "/dev/stderr"; bad = 1 }
  $3 == "Alt" && $4 !~ /^Alt-/ { printf "Alt-category key must use Alt: %s\n", $4 > "/dev/stderr"; bad = 1 }
  $3 == "Space" && $4 !~ /^Space/ { printf "Space-category key must use Space: %s\n", $4 > "/dev/stderr"; bad = 1 }
  { keys[$2 SUBSEP $4] = 1 }
  END {
    for (key in keys) {
      split(key, parts, SUBSEP)
      shifted = parts[2]
      if (shifted ~ /^Cmd-Shift-/) {
        base = shifted; sub(/^Cmd-Shift-/, "Cmd-", base)
        if (!keys[parts[1] SUBSEP base]) { printf "shifted key has no base action: %s\n", shifted > "/dev/stderr"; bad = 1 }
      }
      if (shifted ~ /^Alt-Shift-/) {
        base = shifted; sub(/^Alt-Shift-/, "Alt-", base)
        if (!keys[parts[1] SUBSEP base]) { printf "shifted key has no base action: %s\n", shifted > "/dev/stderr"; bad = 1 }
      }
    }
    exit bad
  }
' "$registry"

while IFS=$'\t' read -r id layer _category _key _action _description; do
  [[ "$id" == \#* || -z "$id" ]] && continue
  case "$layer" in
    Ghostty) config="$HOME/.config/ghostty/config" ;;
    tmux) config="$HOME/.config/tmux/tmux.conf" ;;
    Neovim) config="$HOME/.config/nvim/lua/fausto/keymaps.lua" ;;
    *) printf 'unknown layer for %s: %s\n' "$id" "$layer" >&2; exit 1 ;;
  esac
  marker="km:$id"
  [[ "$layer" == "Neovim" ]] && marker="'$id'"
  if [[ ! -f "$config" ]] || ! grep -Fq "$marker" "$config"; then
    printf 'binding missing from %s: %s\n' "$config" "$id" >&2
    exit 1
  fi

  if [[ "$layer" == "tmux" && ("$_category" == "Command" || "$_category" == "Alt") ]]; then
    if ! grep -Fq "km:$id" "$HOME/.config/ghostty/config" && [[ "$_category" == "Command" ]]; then
      printf 'Command translation missing from Ghostty: %s\n' "$id" >&2
      exit 1
    fi
  fi
done < "$registry"

if [[ "${1:-}" == "--check" ]]; then
  awk -v table="$table" '
    /<!-- KEYMAPS:START -->/ { print; while ((getline line < table) > 0) print line; skip=1; next }
    /<!-- KEYMAPS:END -->/ { skip=0 }
    !skip { print }
  ' "$reference" > "$rendered"
  cmp -s "$rendered" "$reference" || {
    printf 'keymap section is stale; run keymap-docs\n' >&2
    exit 1
  }
  printf 'keymap registry and manual are consistent\n'
else
  awk -v table="$table" '
    /<!-- KEYMAPS:START -->/ { print; while ((getline line < table) > 0) print line; skip=1; next }
    /<!-- KEYMAPS:END -->/ { skip=0 }
    !skip { print }
  ' "$reference" > "$rendered"
  cp "$rendered" "$reference"
  printf 'updated keymaps in %s\n' "$reference"
fi
