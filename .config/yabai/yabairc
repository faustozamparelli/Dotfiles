#!/usr/bin/env sh

# Tile normal windows
yabai -m config layout bsp

# New windows normally appear on the right
yabai -m config window_placement second_child

# Begin new splits at exactly 50/50
yabai -m config split_ratio 0.50

# Always use a vertical divider for BSP windows: side by side, never top/bottom.
yabai -m config split_type vertical

# Keep manual window resizing
yabai -m config auto_balance off

# Use the full usable display area: no outer padding and no gaps between tiles.
yabai -m config top_padding 0
yabai -m config bottom_padding 0
yabai -m config left_padding 0
yabai -m config right_padding 0
yabai -m config window_gap 0

# Predictable keyboard-driven focus
yabai -m config focus_follows_mouse off
yabai -m config mouse_follows_focus off

# Keep transient dialogs, sheets, and floating utility panels out of the BSP tree.
yabai -m rule --add label="float_transient_windows" \
    subrole="^(AXDialog|AXSystemDialog|AXFloatingWindow)$" manage=off

# Compact system utilities and settings windows are more useful at their natural size.
yabai -m rule --add label="float_system_utilities" \
    app="^(Activity Monitor|AirPort Utility|Audio MIDI Setup|Bluetooth File Exchange|Calculator|Clock|ColorSync Utility|Digital Colou?r Meter|Disk Utility|Font Book|Image Capture|Print Center|Screenshot|System Information|System Settings|VoiceOver Utility)$" manage=off

# Installed third-party utilities whose primary windows are controls, launchers, or recorders.
yabai -m rule --add label="float_third_party_utilities" \
    app="^(Karabiner-Elements|Karabiner-EventViewer|KeyboardCleanTool|LinearMouse|MySielteID|QuickRecorder|Raycast|Shottr|Wispr Flow)$" manage=off

# Helium's video overlay should float instead of taking a tile. Match the known PiP
# title variants while leaving normal Helium browser windows managed.
yabai -m rule --add label="float_helium_pip" app="^Helium$" \
    title="^([Pp]icture[- ][Ii]n[- ][Pp]icture|PiP)$" manage=off
