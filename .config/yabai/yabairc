#!/usr/bin/env sh

# Tile normal windows
yabai -m config layout bsp

# New windows normally appear on the right
yabai -m config window_placement second_child

# Begin new splits at exactly 50/50
yabai -m config split_ratio 0.50

# Always use a vertical divider for BSP windows: side by side, never top/bottom.
yabai -m config split_type vertical

# Keep manual window resizing
yabai -m config auto_balance off

# Use the full usable display area: no outer padding and no gaps between tiles.
yabai -m config top_padding 0
yabai -m config bottom_padding 0
yabai -m config left_padding 0
yabai -m config right_padding 0
yabai -m config window_gap 0

# Predictable keyboard-driven focus
yabai -m config focus_follows_mouse off
yabai -m config mouse_follows_focus off
