#!/usr/bin/env bash
set -euo pipefail

target="${1:-${TMUX_PANE:-}}"
if [[ -z "$target" ]] || ! tmux display-message -p -t "$target" '#{pane_id}' >/dev/null 2>&1; then
  tmux display-message 'toggle-agent: no valid source pane'
  exit 0
fi

window="$(tmux display-message -p -t "$target" '#{session_name}:#{window_index}')"
agent_pane="$(tmux list-panes -t "$window" -F '#{pane_id} #{@codex_agent}' | awk '$2 == 1 { print $1; exit }')"

if [[ -n "$agent_pane" ]]; then
  if [[ "$agent_pane" == "$target" ]]; then
    return_pane="$(tmux show-option -p -qv -t "$agent_pane" @codex_return_pane)"
    if [[ -n "$return_pane" ]] && tmux display-message -p -t "$return_pane" '#{pane_id}' >/dev/null 2>&1; then
      tmux select-pane -t "$return_pane"
    else
      tmux last-pane -t "$window"
    fi
    exit 0
  fi

  tmux set-option -p -t "$agent_pane" @codex_return_pane "$target"
  tmux select-pane -t "$agent_pane"
  exit 0
fi

cwd="$(tmux display-message -p -t "$target" '#{pane_current_path}')"
agent_pane="$(tmux split-window -h -p 40 -t "$target" -c "$cwd" -P -F '#{pane_id}' 'exec codex')"
tmux set-option -p -t "$agent_pane" @codex_agent 1
tmux set-option -p -t "$agent_pane" @codex_return_pane "$target"
tmux select-pane -t "$agent_pane" -T 'codex'
tmux select-pane -t "$agent_pane"
