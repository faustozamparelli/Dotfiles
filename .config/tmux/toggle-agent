#!/usr/bin/env bash
set -euo pipefail

target="${TMUX_PANE:?TMUX_PANE is not set}"
window="$(tmux display-message -p -t "$target" '#{session_name}:#{window_index}')"
agent_pane="$(tmux list-panes -t "$window" -F '#{pane_id} #{@codex_agent}' | awk '$2 == 1 { print $1; exit }')"

if [[ -n "$agent_pane" ]]; then
  tmux select-pane -t "$agent_pane"
  exit 0
fi

cwd="$(tmux display-message -p -t "$target" '#{pane_current_path}')"
agent_pane="$(tmux split-window -h -p 40 -c "$cwd" -P -F '#{pane_id}' 'exec codex')"
tmux set-option -p -t "$agent_pane" @codex_agent 1
tmux select-pane -t "$agent_pane"
