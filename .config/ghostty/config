theme =  dark:Dark Pastel, light:Builtin Light
command = /opt/homebrew/bin/fish --login --interactive
confirm-close-surface = false

cursor-style = bar
#cursor-style-blink = false
shell-integration-features = no-cursor

font-size = 20
font-family = "Iosevka NF"
font-feature = "-calt"
title = " "

clipboard-read = allow
clipboard-paste-protection = false

mouse-hide-while-typing = true
#keybind = global:cmd+a=toggle_quick_terminal

split-divider-color = #8a4fff

# macOS specific features
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-option-as-alt = true 
window-save-state = always
window-vsync = true
window-colorspace = display-p3
quick-terminal-screen = macos-menu-bar

#bindings
keybind = cmd+h=previous_tab
keybind = cmd+l=next_tab
keybind = cmd+shift+h=move_tab:-1
keybind = cmd+shift+l=move_tab:1

keybind = cmd+b=new_split:right
keybind = cmd+n=new_split:down
keybind = alt+h=goto_split:left
keybind = alt+l=goto_split:right
keybind = alt+j=goto_split:down
keybind = alt+k=goto_split:up

keybind = alt+shift+h=resize_split:left,30
keybind = alt+shift+j=resize_split:down,30
keybind = alt+shift+k=resize_split:up,30
keybind = alt+shift+l=resize_split:right,30
