command = /opt/homebrew/bin/fish --login --interactive
confirm-close-surface = false
working-directory = home

cursor-style = bar
#cursor-style-blink = false
shell-integration-features = no-cursor

font-size = 20
font-family = "SF Mono"
font-feature = "-calt"
title = " "

clipboard-read = allow
clipboard-paste-protection = false

mouse-hide-while-typing = true
#keybind = global:cmd+a=toggle_quick_terminal

#theme =  dark:/Users/faustozamparelli/.config/ghostty/themes/DarkPastel.conf, light:/Users/faustozamparelli/.config/ghostty/themes/BuiltinLight.conf
# macOS specific features
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-option-as-alt = true 
window-save-state = always
window-vsync = true
window-colorspace = display-p3
quick-terminal-screen = macos-menu-bar

background-opacity = 1.00