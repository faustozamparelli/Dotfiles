theme =  dark:/Users/faustozamparelli/.config/ghostty/themes/DarkPastel.conf, light:/Users/faustozamparelli/.config/ghostty/themes/BuiltinLight.conf

command = /opt/homebrew/bin/fish --login --interactive
confirm-close-surface = false
working-directory = home

cursor-style = bar
#cursor-style-blink = false
shell-integration-features = no-cursor

font-size = 20
font-family = "SF Mono"
font-feature = "-calt"
title = " "

clipboard-read = allow
clipboard-paste-protection = false

mouse-hide-while-typing = true
#keybind = global:cmd+a=toggle_quick_terminal

# Make Cmd+C / Cmd+V reach terminal apps like micro, so micro can copy/paste
# its own selected text instead of Ghostty only copying terminal selection.
keybind = super+c=text:\x03
keybind = super+v=text:\x16
keybind = super+x=text:\x18
keybind = super+z=text:\x1a

# macOS specific features
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-option-as-alt = true 
window-save-state = always
window-vsync = true
window-colorspace = display-p3
quick-terminal-screen = macos-menu-bar

background-opacity = 1.00