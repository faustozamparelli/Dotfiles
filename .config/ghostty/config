theme =  dark:/Users/faustozamparelli/.config/ghostty/themes/DarkPastel.conf, light:/Users/faustozamparelli/.config/ghostty/themes/BuiltinLight.conf
command = /opt/homebrew/bin/fish --login --interactive
confirm-close-surface = false
working-directory = home

cursor-style = bar
#cursor-style-blink = false
shell-integration-features = no-cursor

font-size = 12
font-family = "SF Mono"
font-feature = "-calt"
title = " "

clipboard-read = allow
clipboard-paste-protection = false

mouse-hide-while-typing = true
# macOS specific features
macos-titlebar-style = tabs
macos-window-buttons = hidden
macos-option-as-alt = true 
window-save-state = always
window-vsync = true
window-colorspace = display-p3
quick-terminal-screen = macos-menu-bar

# Codex uses Ctrl+J (LF) for a newline in the prompt.
keybind = shift+enter=text:\x0a

# tmux owns windows and panes. Ghostty only translates Command shortcuts.
# km:ghostty.escape
keybind = cmd+a=text:\x1b
# km:tmux.window.previous
keybind = cmd+h=text:\x1b[5;30010~
# km:tmux.window.next
keybind = cmd+l=text:\x1b[5;30011~
# km:tmux.window.move-left
keybind = cmd+shift+h=text:\x1b[5;30012~
# km:tmux.window.move-right
keybind = cmd+shift+l=text:\x1b[5;30013~
# km:tmux.pane.split-right
keybind = cmd+b=text:\x1b[5;30014~
# km:tmux.pane.split-down
keybind = cmd+n=text:\x1b[5;30015~
# km:tmux.agent.toggle
keybind = cmd+g=text:\x1b[5;30016~
# km:tmux.pane.close
keybind = cmd+w=text:\x1b[5;30017~
# km:tmux.window.new
keybind = cmd+t=text:\x1b[5;30018~
# km:tmux.copy-mode.enter
keybind = cmd+shift+u=text:\x1b[5;30019~

# Disable Ghostty workspace defaults that would compete with tmux.
keybind = cmd+d=unbind
keybind = cmd+shift+d=unbind
keybind = cmd+[=unbind
keybind = cmd+]=unbind
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind

background-opacity = 1.00
